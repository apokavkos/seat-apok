{
    "name": "apokavkos/seat-importing",
    "description": "SeAT plugin for market hub import analysis and stock level monitoring",
    "type": "seat-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Apokavkos",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Apokavkos\\SeatImporting\\": "src/"
        }
    },
    "extra": {
        "seat": {
            "version": "^5.0"
        },
        "laravel": {
            "providers": [
